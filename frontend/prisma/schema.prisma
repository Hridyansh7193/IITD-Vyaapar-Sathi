generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  passwordHash   String?
  businessName   String?
  createdAt      DateTime        @default(now())
  datasets       Dataset[]
  chatSessions   ChatSession[]

  @@map("users_meta")
}

model Dataset {
  id              String            @id @default(cuid())
  userId          String
  filename        String
  totalRevenue    Float?
  totalOrders     Int?
  avgOrderValue   Float?
  analyticsJson   String?
  createdAt       DateTime          @default(now())
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatSessions    ChatSession[]

  @@map("datasets")
}

model ChatSession {
  id          String        @id @default(cuid())
  userId      String
  datasetId   String?
  title       String?
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataset     Dataset?      @relation(fields: [datasetId], references: [id])
  messages    ChatMessage[]

  @@map("chat_sessions_meta")
}

model ChatMessage {
  id            String      @id @default(cuid())
  sessionId     String
  role          String      // "user" | "assistant"
  content       String
  createdAt     DateTime    @default(now())
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages_meta")
}
